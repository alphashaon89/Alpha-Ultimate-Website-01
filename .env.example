# ═══════════════════════════════════════════════════════════
#  Alpha Ultimate — Environment Variables
#  Copy this file to .env.local for local development.
#  Set these in your Vercel project's Environment Variables.
# ═══════════════════════════════════════════════════════════

# ── Admin Credentials ───────────────────────────────────────
# Change both before going live.
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe_UseLong&StrongPassword!

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# ── Yusra AI Assistant (Gemini) ─────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# VITE_ prefix exposes this to the browser bundle.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Email Delivery (choose one) ─────────────────────────────
# Option A: Resend (recommended) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# Option B: SendGrid — https://sendgrid.com
# SENDGRID_API_KEY=SG.your_sendgrid_key

# Email addresses
CONTACT_EMAIL=info@alpha-ultimate.com
FROM_EMAIL=noreply@alpha-ultimate.com

# ── Content Persistence (Vercel KV) ─────────────────────────
# Auto-set when you add a KV database in Vercel Dashboard.
# Vercel Dashboard → Project → Storage → Create KV → Link project
# KV_REST_API_URL=https://xxx.kv.vercel-storage.com
# KV_REST_API_TOKEN=your_kv_token

# ── File Upload Storage (choose one) ────────────────────────
# Option A: Vercel Blob (recommended) — auto-set when linked
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Option B: Cloudinary — https://cloudinary.com
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
